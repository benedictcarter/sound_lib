# --- Generated index (derived data, can be rebuilt by indexer) ---
/index.json
/app/index.json
/app/embeddings.npz
# atomic-write temp/backup artifacts (userdata/chopping/loudness/index)
*.json.tmp
*.json.bak

# NOTE: your data (ratings/plays/tags -> userdata.json) and gap-analysis results
# (analysis.json) now live in the library data folder (library_root, e.g.
# S:\code\sound_lib_data), OUTSIDE this repo, so they can't be committed and are
# never touched by repo cleanup. These entries remain only to catch stray copies.
/app/userdata.json
/app/analysis.json

# --- Godot editor cache / build artifacts ---
/app/.godot/
/app/android/
/app/export_presets.cfg
*.translation

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- Audio files (belt & braces: the library lives outside the repo in
#     S:\code\sound_lib_data, but never let audio sneak into git) ---
*.wav
*.WAV
*.aif
*.aiff
*.flac
*.mp3
*.ogg
*.m4a
*.wma
*.aac

# --- OS cruft ---
Thumbs.db
.DS_Store
